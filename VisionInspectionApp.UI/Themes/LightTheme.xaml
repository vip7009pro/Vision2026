<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F9F9F9" />
    <SolidColorBrush x:Key="PanelAltBackgroundBrush" Color="#F1F1F1" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="DarkBorderBrush" Color="#CCCCCC" />
    
    <SolidColorBrush x:Key="TextBrush" Color="#333333" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#555555" />
    
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#EFEFEF" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#E5E5E5" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#CCCCCC" />

    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputTextBrush" Color="#000000" />
    
    <SolidColorBrush x:Key="AccentBrush" Color="#1865F5" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />

</ResourceDictionary>
