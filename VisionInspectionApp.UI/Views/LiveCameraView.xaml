<UserControl x:Class="VisionInspectionApp.UI.Views.LiveCameraView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:local="clr-namespace:VisionInspectionApp.UI.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Control Panel -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Live Camera Inspection" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Camera Selection -->
                <TextBlock Grid.Column="0" Text="Camera:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableCameras}" SelectedItem="{Binding SelectedCamera}" 
                         IsEnabled="{Binding IsCameraRunning, Converter={StaticResource InverseBoolConverter}}" />

                <!-- Config Selection -->
                <TextBlock Grid.Column="2" Text="Config:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="Bold" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding AvailableConfigs}" SelectedItem="{Binding SelectedConfig}" 
                         IsEnabled="{Binding IsCameraRunning, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>

            <!-- RTSP Url Input (Visible only when RTSP is selected) -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding IsRtspSelected, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="RTSP URL:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" />
                <TextBox Width="500" Text="{Binding RtspUrl, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Padding="4,2" 
                         IsEnabled="{Binding IsCameraRunning, Converter={StaticResource InverseBoolConverter}}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Command="{Binding StartCameraCommand}" Padding="10,8" Background="#4CAF50" Foreground="White" Margin="0,0,10,0"
                       IsEnabled="{Binding IsCameraRunning, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Margin="0,0,5,0" />
                        <TextBlock Text="Start Camera" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding StopCameraCommand}" Padding="10,8" Background="#F44336" Foreground="White" Margin="0,0,10,0"
                       IsEnabled="{Binding IsCameraRunning}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏹" Margin="0,0,5,0" />
                        <TextBlock Text="Stop Camera" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding ToggleLiveInspectionCommand}" Padding="10,8" Background="#2196F3" Foreground="White" Margin="0,0,10,0"
                       IsEnabled="{Binding IsCameraRunning}">
                    <TextBlock Text="{Binding IsLiveInspectionEnabled, StringFormat='Live Inspection: {0}'}" />
                </Button>

                <Button Command="{Binding CaptureSnapshotCommand}" Padding="10,8" Background="#FF9800" Foreground="White"
                       IsEnabled="{Binding IsCameraRunning}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📷" Margin="0,0,5,0" />
                        <TextBlock Text="Snapshot" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}" Foreground="#666" Margin="0,10,0,0" FontSize="12" />
            <TextBlock Text="{Binding Fps, StringFormat='FPS: {0}'}" Foreground="#666" Margin="0,5,0,0" FontSize="12" FontWeight="Bold" />
        </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Live Video Display -->
            <Border Grid.Column="0" Background="Black" Margin="5">
                <Image Source="{Binding LiveImage}" Stretch="UniformToFill" />
            </Border>

            <!-- Results Panel -->
            <Border Grid.Column="1" Width="300" Background="{DynamicResource PanelBackgroundBrush}" Margin="0,5,5,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Live Results" FontWeight="Bold" Padding="10" Background="{DynamicResource PanelAltBackgroundBrush}" />

                    <TextBlock Text="{Binding LastInspectionResult}" Padding="10,5" FontSize="12" Foreground="{DynamicResource TextBrush}" />

                    <ListBox ItemsSource="{Binding LiveResults}" Background="{DynamicResource PanelBackgroundBrush}" Padding="10" MaxHeight="400">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap" Margin="0,2" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

