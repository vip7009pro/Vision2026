<Window x:Class="VisionInspectionApp.UI.Views.PortValueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Port Value" Height="250" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Grid.Row="0" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="{DynamicResource TextBrush}" />

        <TextBox x:Name="ValueTextBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="5" />

        <Button Grid.Row="2" Content="Close" Width="80" Height="25" HorizontalAlignment="Right" Margin="0,10,0,0" Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource ButtonTextBrush}" Click="CloseButton_Click" />
    </Grid>
</Window>
