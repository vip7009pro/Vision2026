                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Circle" Width="60" VerticalAlignment="Center" />
                                    <ComboBox Width="160" ItemsSource="{Binding AvailableCircleFinderNames}" SelectedItem="{Binding Dia_CircleRef, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsEdgePairDetectNode, Converter={StaticResource BoolToVis}}">
