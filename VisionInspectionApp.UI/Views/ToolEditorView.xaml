                                            <TextBlock Text="Strip Length" VerticalAlignment="Center" Margin="8,4" Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}">
                                            <TextBox Text="{Binding Epd_StripLength, UpdateSourceTrigger=PropertyChanged, Delay=250}" Margin="4" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                            <TextBlock Text="Min Gradient" VerticalAlignment="Center" Margin="8,4" Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}">
                                            <TextBox Text="{Binding Epd_MinEdgeStrength, UpdateSourceTrigger=PropertyChanged, Delay=250}" Margin="4" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                            <TextBlock Text="Min Separation" VerticalAlignment="Center" Margin="8,4" Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}">
                                            <TextBox Text="{Binding Epd_MinEdgeSeparationPx, UpdateSourceTrigger=PropertyChanged, Delay=250}" Margin="4" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <TextBlock Text="Spec" FontWeight="SemiBold" Margin="0,6,0,6" />
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                            <TextBlock Text="Nominal" VerticalAlignment="Center" Margin="8,4" Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}">
                                            <TextBox Text="{Binding Distance_Nominal, UpdateSourceTrigger=PropertyChanged, Delay=250}" Margin="4" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                            <TextBlock Text="Tolerance+" VerticalAlignment="Center" Margin="8,4" Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}">
                                            <TextBox Text="{Binding Distance_TolPlus, UpdateSourceTrigger=PropertyChanged, Delay=250}" Margin="4" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                            <TextBlock Text="Tolerance-" VerticalAlignment="Center" Margin="8,4" Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}">
                                            <TextBox Text="{Binding Distance_TolMinus, UpdateSourceTrigger=PropertyChanged, Delay=250}" Margin="4" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="Value" Width="60" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedRunValue, TargetNullValue='-'}" Width="120" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Pass" Width="60" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedRunPass, TargetNullValue='-'}" Width="120" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsCodeDetectionNode, Converter={StaticResource BoolToVis}}">
                                <Border Background="{DynamicResource BorderBrush}" Padding="4,2" Margin="0,8,0,0">
                                    <TextBlock Text="Code Detection" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                                </Border>

                                <CheckBox Content="Try Harder" IsChecked="{Binding Cdt_TryHarder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />

                                <TextBlock Text="Symbologies" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <CheckBox Content="QR" IsChecked="{Binding Cdt_EnableQr, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Barcode 1D" IsChecked="{Binding Cdt_EnableBarcode1D, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="DataMatrix" IsChecked="{Binding Cdt_EnableDataMatrix, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="PDF417" IsChecked="{Binding Cdt_EnablePdf417, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Aztec" IsChecked="{Binding Cdt_EnableAztec, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Text" Width="60" VerticalAlignment="Top" />
                                    <TextBlock Text="{Binding SelectedRunText, TargetNullValue='-'}" TextWrapping="Wrap" Width="160" />
                                </StackPanel>
                            </StackPanel>

                            <Button Content="Delete Node" Command="{Binding DeleteSelectedNodeCommand}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource DarkBorderBrush}" />

            <Border Grid.Column="2" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" Padding="8" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="Bold" Text="Canvas" VerticalAlignment="Center" />
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="RefName:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0" />
                            <TextBox Text="{Binding SelectedNode.RefName, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4,2" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="🌗 Theme" Height="28" Padding="12,0" Margin="0,0,6,0" Click="BtnToggleTheme_Click" Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" FontWeight="SemiBold" ToolTip="Toggle Dark/Light Mode" />
                            <Button Content="⚙ Global Pre-processor" Height="28" Padding="12,0" Click="BtnGlobalPreprocess_Click" Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" FontWeight="SemiBold" ToolTip="Open Global Image Pre-processor Settings" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer x:Name="CanvasScrollViewer" Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="EditorCanvas" Background="Transparent" Width="2000" Height="2000" AllowDrop="True" Drop="EditorCanvas_Drop" MouseMove="EditorCanvas_MouseMove" MouseLeftButtonUp="EditorCanvas_MouseLeftButtonUp"
                                Focusable="True" PreviewKeyDown="EditorCanvas_PreviewKeyDown" PreviewMouseWheel="EditorCanvas_PreviewMouseWheel">
                            <Canvas.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding CanvasZoom}" ScaleY="{Binding CanvasZoom}" />
                            </Canvas.LayoutTransform>

                            <ItemsControl ItemsSource="{Binding Edges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Path Data="{Binding PathData}" Stroke="#2E7DFF" StrokeThickness="2"
                                              MouseLeftButtonDown="Edge_MouseLeftButtonDown" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Path x:Name="WirePreviewPath" Stroke="#FF9800" StrokeThickness="2" Visibility="Collapsed" />

                            <Rectangle x:Name="SelectionRect" Visibility="Collapsed" IsHitTestVisible="False"
                                       Stroke="#FF9800" StrokeThickness="1" StrokeDashArray="4 2"
                                       Fill="#33FF9800" />

                            <ItemsControl ItemsSource="{Binding Nodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Thumb DragStarted="NodeThumb_DragStarted" DragDelta="NodeThumb_DragDelta" DragCompleted="NodeThumb_DragCompleted" MouseLeftButtonDown="NodeThumb_MouseLeftButtonDown">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid Width="160" Height="{Binding NodeHeight}">
                                                        <Border CornerRadius="4" Padding="8" Margin="0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="BorderBrush" Value="#666" />
                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                    <Setter Property="Background" Value="#FFF" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#FF9800" />
                                                                            <Setter Property="BorderThickness" Value="2" />
                                                                            <Setter Property="Background" Value="#FFF8E1" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <DockPanel LastChildFill="True">
                                                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                                                    <TextBlock FontWeight="Bold" Text="{Binding Type}" />
                                                                    <TextBlock Text="{Binding RefName}" Foreground="{DynamicResource TextMutedBrush}" />
                                                                </StackPanel>

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <ItemsControl Grid.Column="0" ItemsSource="{Binding InPorts}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-6,0,0,0">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Vertical" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Tag="{Binding Tag}" Margin="0,4,0,4">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="12" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Ellipse Width="12" Height="12" Fill="#2ECC71" Stroke="#1B5E20" StrokeThickness="1" />
                                                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" FontSize="11" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>

                                                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding OutPorts}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-6,0">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Vertical" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Tag="{Binding Tag}" Margin="0,4,0,4">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                        <ColumnDefinition Width="12" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" FontSize="11" />
                                                                                    <Ellipse Grid.Column="1" Width="12" Height="12" Fill="#2E7DFF" Stroke="#0D47A1" StrokeThickness="1"
                                                                                             MouseLeftButtonDown="OutPort_MouseLeftButtonDown" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Grid>
                                                            </DockPanel>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource DarkBorderBrush}" />

            <Border Grid.Column="4" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="Bold" Text="Preview - Selected Node" Margin="0,0,0,6" />
                    <CheckBox Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center" Content="Show ROI" IsChecked="{Binding ShowRoisInSelectedPreview, UpdateSourceTrigger=PropertyChanged}" />
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="Transparent">
                        <controls:ImageViewerControl ImageSource="{Binding SelectedNodePreviewImage}"
                                                  OverlayItems="{Binding SelectedNodeOverlayItems}"
                                                  EnableRoiEditing="True" ActiveRoiLabel="{Binding ActiveRoiLabel, Mode=TwoWay}"
                                                  RoiSelectedCommand="{Binding RoiSelectedCommand}"
                                                  PointClickedCommand="{Binding PointClickedCommand}"
                                                  PointDoubleClickedCommand="{Binding PointDoubleClickedCommand}"
                                                  RoiEditedCommand="{Binding RoiEditedCommand}"
                                                  RoiDeletedCommand="{Binding RoiDeletedCommand}" />
                    </Border>

                    <TextBlock Grid.Row="2" FontWeight="Bold" Text="Preview - Final Output" Margin="0,10,0,6" />
                    <CheckBox Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,10,0,6" Content="Show ROI" IsChecked="{Binding ShowRoisInFinalPreview, UpdateSourceTrigger=PropertyChanged}" />
                    <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="Transparent">
                        <controls:ImageViewerControl ImageSource="{Binding FinalPreviewImage}" OverlayItems="{Binding FinalOverlayItems}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>



