                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Found" Width="60" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedRunPass, TargetNullValue='-'}" Width="120" />
                                </StackPanel>
