                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Tag="{Binding Tag}" Margin="0,4,0,4">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="12" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Ellipse Width="12" Height="12" Fill="#2ECC71" Stroke="#1B5E20" StrokeThickness="1" />
                                                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" FontSize="11" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>

                                                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding OutPorts}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-6,0">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Vertical" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Tag="{Binding Tag}" Margin="0,4,0,4">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                        <ColumnDefinition Width="12" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" FontSize="11" />
                                                                                    <Ellipse Grid.Column="1" Width="12" Height="12" Fill="#2E7DFF" Stroke="#0D47A1" StrokeThickness="1"
                                                                                             MouseLeftButtonDown="OutPort_MouseLeftButtonDown" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Grid>
                                                            </DockPanel>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource DarkBorderBrush}" />

            <!-- Column 4: Single Image Preview Box -->
            <Border Grid.Column="4" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding SelectedNode.RefName, StringFormat='📌 Preview: {0}'}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsResultViewNode}" Value="True">
                                                <Setter Property="Text" Value="📊 Preview: Result View (Final Output)" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                                <Setter Property="Text" Value="📌 Preview" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Show Results" IsChecked="{Binding ShowResultOverlay, UpdateSourceTrigger=LostFocus}" Margin="0,0,10,0" />
                            <CheckBox Content="Show ROI" IsChecked="{Binding ShowRoisInSelectedPreview, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="Black">
                        <controls:ImageViewerControl ImageSource="{Binding SelectedNodePreviewImage}"
                                                   OverlayItems="{Binding SelectedNodeOverlayItems}"
                                                   EnableRoiEditing="{Binding EnableRoiEditingInPreview}" ActiveRoiLabel="{Binding ActiveRoiLabel, Mode=TwoWay}"
                                                   RoiSelectedCommand="{Binding RoiSelectedCommand}"
                                                   PointClickedCommand="{Binding PointClickedCommand}"
                                                   PointDoubleClickedCommand="{Binding PointDoubleClickedCommand}"
                                                   RoiEditedCommand="{Binding RoiEditedCommand}"
                                                   RoiDeletedCommand="{Binding RoiDeletedCommand}" />
                    </Border>
                </Grid>
            </Border>

            <!-- Column 5: GridSplitter -->
            <GridSplitter Grid.Column="5" Width="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource DarkBorderBrush}" />

            <!-- Column 6: Integrated Live Inspection Dashboard & Details -->
            <Border Grid.Column="6" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Status Pill Badge & Summary Card -->
                    <Border Grid.Row="0" Padding="10,6" CornerRadius="8" Margin="0,0,0,6"
                            Background="{Binding ResultBackgroundBrush}"
                            BorderBrush="{Binding ResultBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding ResultStatusText}" FontSize="24" FontWeight="Bold" Foreground="{Binding ResultForegroundBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding OriginScoreText}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="{Binding NgReasonsText}" FontSize="10" Foreground="#D32F2F" TextWrapping="Wrap" MaxHeight="36" Visibility="{Binding IsNg, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding LastResult.Timings.TotalMs, StringFormat='Total: {0} ms'}" Foreground="#4CAF50" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable inspection tables & runtime details -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="2">
                            <!-- Timing Breakdown Bar -->
                            <WrapPanel Margin="0,0,0,8" TextElement.Foreground="{DynamicResource TextBrush}">
                                <TextBlock Text="{Binding LastResult.Pass, StringFormat='PASS: {0}'}" FontWeight="Bold" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding LastResult.Timings.TotalMs, StringFormat='Total: {0}ms'}" Foreground="#4CAF50" FontWeight="Bold" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding LastResult.Timings.OriginMs, StringFormat='O: {0}ms'}" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding LastResult.Timings.PointsMs, StringFormat='P: {0}ms'}" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding LastResult.Timings.LinesMs, StringFormat='L: {0}ms'}" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding LastResult.Timings.DistancesMs, StringFormat='D: {0}ms'}" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding LastResult.Timings.ConditionsMs, StringFormat='Cnd: {0}ms'}" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding LastResult.Timings.DefectsMs, StringFormat='Def: {0}ms'}" Margin="0,0,6,0" />
                            </WrapPanel>

                            <!-- Section 1: Spec Measurements Table -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4" Margin="0,0,0,8" Background="{DynamicResource PanelBackgroundBrush}">
                                <StackPanel>
                                    <TextBlock Text="📏 BẢNG KẾT QUẢ ĐO ĐẠC (SPEC MEASUREMENTS)" FontWeight="Bold" FontSize="11" Margin="2,2,0,4" Foreground="{DynamicResource TextBrush}" />
                                    <DataGrid ItemsSource="{Binding SpecResults}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="Horizontal" MinHeight="80" MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Tool" Binding="{Binding Tool}" Width="65" />
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="95" />
                                            <DataGridTextColumn Header="A" Binding="{Binding RefA}" Width="70" />
                                            <DataGridTextColumn Header="B" Binding="{Binding RefB}" Width="70" />
                                            <DataGridTextColumn Header="Value (mm)" Binding="{Binding Value, StringFormat={}{0:0.000}}" Width="90" />
                                            <DataGridTextColumn Header="Nominal" Binding="{Binding Nominal, StringFormat={}{0:0.000}}" Width="80" />
                                            <DataGridTextColumn Header="+Tol" Binding="{Binding TolPlus, StringFormat={}{0:0.000}}" Width="55" />
                                            <DataGridTextColumn Header="-Tol" Binding="{Binding TolMinus, StringFormat={}{0:0.000}}" Width="55" />
                                            <DataGridCheckBoxColumn Header="Pass" Binding="{Binding Pass}" Width="45" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Section 2: Conditions Logic Table -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4" Margin="0,0,0,8" Background="{DynamicResource PanelBackgroundBrush}">
                                <StackPanel>
                                    <TextBlock Text="❓ ĐIỀU KIỆN LOGIC (CONDITIONS LOGIC)" FontWeight="Bold" FontSize="11" Margin="2,2,0,4" Foreground="{DynamicResource TextBrush}" />
                                    <DataGrid ItemsSource="{Binding LastResult.Conditions}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="Horizontal" MinHeight="60" MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="95" />
                                            <DataGridTextColumn Header="Expression" Binding="{Binding Expression}" Width="*" />
                                            <DataGridTextColumn Header="Result" Binding="{Binding Pass, Converter={StaticResource OkNgConv}}" Width="65" />
                                            <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Section 3: Per-Tool Execution Timings -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4" Margin="0,0,0,8" Background="{DynamicResource PanelBackgroundBrush}">
                                <StackPanel>
                                    <TextBlock Text="⏱ THỜI GIAN CHẠY TỪNG TOOL (PER-TOOL TIMINGS)" FontWeight="Bold" FontSize="11" Margin="2,2,0,4" Foreground="{DynamicResource TextBrush}" />
                                    <DataGrid ItemsSource="{Binding ToolTimings}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="Horizontal" MinHeight="60" MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Tool Node Name" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Thời gian (ms)" Binding="{Binding TimeMs}" Width="120" FontWeight="Bold" Foreground="#4CAF50" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Section 4: Code Detection & SurfaceCompare Debugger -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4" Margin="0,0,0,4" Background="{DynamicResource PanelBackgroundBrush}">
                                <StackPanel>
                                    <TextBlock Text="📷 ĐỌC MÃ VẠCH / QR &amp; SURFACE COMPARE DEBUG" FontWeight="Bold" FontSize="11" Margin="2,2,0,4" Foreground="{DynamicResource TextBrush}" />
                                    
                                    <ItemsControl ItemsSource="{Binding CodeDetectionResults}" Margin="0,0,0,6">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,4" Background="{DynamicResource PanelBackgroundBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name, StringFormat='Name: {0}'}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Text, StringFormat='Text: {0}', TargetNullValue='-'}" TextWrapping="Wrap" Foreground="#2E7D32" FontWeight="Bold" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ComboBox ItemsSource="{Binding SurfaceCompareDebugItems}" SelectedItem="{Binding SelectedSurfaceCompareDebugPick}" DisplayMemberPath="DisplayName" Margin="0,2,0,6" />
                                    
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="2">
                                            <TextBlock Text="Template" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                            <Border BorderThickness="1" BorderBrush="#AAA" Background="Black">
                                                <Image Source="{Binding DebugTemplate}" Stretch="Uniform" Height="70" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="Current" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                            <Border BorderThickness="1" BorderBrush="#AAA" Background="Black">
                                                <Image Source="{Binding DebugCurrent}" Stretch="Uniform" Height="70" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="Diff Thô" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                            <Border BorderThickness="1" BorderBrush="#AAA" Background="Black">
                                                <Image Source="{Binding DebugBinary}" Stretch="Uniform" Height="70" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="Diff Morphed" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                            <Border BorderThickness="1" BorderBrush="#AAA" Background="Black">
                                                <Image Source="{Binding DebugDiff}" Stretch="Uniform" Height="70" />
                                            </Border>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2" Background="{DynamicResource DarkBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DarkBorderBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusBarText}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding TotalExecutionTimeMs, StringFormat='{}Total Time: {0} ms'}" Foreground="#4CAF50" FontWeight="SemiBold" />
            </StatusBarItem>
        </StatusBar>
</Grid>
</UserControl>




