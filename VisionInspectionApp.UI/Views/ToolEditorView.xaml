                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Ori" Width="60" VerticalAlignment="Center" />
                                    <ComboBox Width="160" ItemsSource="{Binding AvailableCaliperOrientations}" SelectedItem="{Binding Epd_Orientation, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Pol" Width="60" VerticalAlignment="Center" />
                                    <ComboBox Width="160" ItemsSource="{Binding AvailableEdgePolarities}" SelectedItem="{Binding Epd_Polarity, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="Strips" Width="60" VerticalAlignment="Center" />
                                    <TextBox Width="80" Text="{Binding Epd_StripCount, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
