                                        <TextBox Width="80" Text="{Binding Cf_Canny1, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="C2" Width="60" VerticalAlignment="Center" />
                                        <TextBox Width="80" Text="{Binding Cf_Canny2, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,6">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Cf_Algorithm}" Value="{x:Static models:CircleFindAlgorithm.ContourFit}">
                                                    <Setter Property="Visibility" Value="Visible" />
