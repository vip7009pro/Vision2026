<UserControl x:Class="VisionInspectionApp.UI.Views.CameraSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:VisionInspectionApp.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource PanelAltBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Live Stream View -->
        <Border Grid.Column="0" Background="#1E1E1E" Margin="10" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" ClipToBounds="True">
            <Grid>
                <!-- Live Image Display -->
                <Image Source="{Binding LiveImage}" Stretch="Uniform" />

                <!-- HUD Info Overlay -->
                <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15" Background="#80000000" Padding="8,4" CornerRadius="4">
                    <TextBlock Text="{Binding Fps, StringFormat='FPS: {0}'}" Foreground="#4CAF50" FontWeight="Bold" FontSize="14" />
                </Border>

                <!-- Offline Placeholder -->
                <Grid Visibility="{Binding LiveImage, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📷" FontSize="48" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,10" />
                        <TextBlock Text="Camera chưa khởi chạy" FontSize="16" Foreground="#888" HorizontalAlignment="Center" />
                        <TextBlock Text="Vui lòng qua tab Live Camera để kết nối trước khi cấu hình" FontSize="12" Foreground="#666" HorizontalAlignment="Center" Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Right Panel: Adjustment Settings -->
        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}" Margin="0,10,10,10" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header Title -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Camera Settings" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="Căn chỉnh các bộ lọc hình ảnh đầu vào" FontSize="12" Foreground="#888" Margin="0,2,0,0" />
                    <Separator Margin="0,10,0,0" />
                </StackPanel>

                <!-- Adjusters Controls -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <StackPanel Orientation="Vertical">
                        
                        <!-- Brightness Adjuster -->
                        <GroupBox Header="Độ Sáng (Brightness)" Margin="0,0,0,15" Padding="5" FontWeight="SemiBold" BorderBrush="#EEE">
                            <StackPanel Margin="5">
                                <Grid Margin="0,0,0,5">
                                    <TextBlock Text="Cân bằng sáng tối" FontSize="11" Foreground="#888" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Brightness, StringFormat='{}{0:F0}'}" FontSize="12" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Right" />
                                </Grid>
                                <Slider Minimum="-100" Maximum="100" Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}" 
                                        TickFrequency="5" IsSnapToTickEnabled="False" Margin="0,5,0,0" />
                                <Grid Margin="0,2,0,0">
                                    <TextBlock Text="Tối (-100)" FontSize="10" Foreground="#AAA" />
                                    <TextBlock Text="Sáng (+100)" FontSize="10" Foreground="#AAA" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Contrast Adjuster -->
                        <GroupBox Header="Độ Tương Phản (Contrast)" Margin="0,0,0,15" Padding="5" FontWeight="SemiBold" BorderBrush="#EEE">
                            <StackPanel Margin="5">
                                <Grid Margin="0,0,0,5">
                                    <TextBlock Text="Độ sắc nét biên độ ảnh" FontSize="11" Foreground="#888" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Contrast, StringFormat='{}{0:F2}'}" FontSize="12" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Right" />
                                </Grid>
                                <Slider Minimum="0.5" Maximum="3.0" Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}" 
                                        TickFrequency="0.05" IsSnapToTickEnabled="False" Margin="0,5,0,0" />
                                <Grid Margin="0,2,0,0">
                                    <TextBlock Text="Nhạt (0.5)" FontSize="10" Foreground="#AAA" />
                                    <TextBlock Text="Gắt (3.0)" FontSize="10" Foreground="#AAA" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Colorspace Conversion -->
                        <GroupBox Header="Chế Độ Hiển Thị (Color Mode)" Margin="0,0,0,15" Padding="5" FontWeight="SemiBold" BorderBrush="#EEE">
                            <StackPanel Margin="5">
                                <CheckBox IsChecked="{Binding IsGrayscale, UpdateSourceTrigger=PropertyChanged}" Content="Chuyển sang ảnh Đen Trắng (Grayscale)" 
                                          FontSize="12" Margin="0,5,0,0" Padding="5,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="Đầu vào đen trắng giúp tăng độ ổn định của các bộ lọc biên dạng và tối ưu bộ nhớ xử lý." 
                                           FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="5,5,0,0" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer Status and Reset -->
                <StackPanel Grid.Row="2">
                    <Separator Margin="0,0,0,10" />
                    <Button Command="{Binding ResetSettingsCommand}" Content="Khôi phục mặc định" Padding="8" Background="{DynamicResource PanelAltBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#666" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

