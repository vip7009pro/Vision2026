<UserControl x:Class="VisionInspectionApp.UI.Views.PlcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel>
                <TextBlock Text="PLC Communication (Mitsubishi - MX Component)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

                <WrapPanel Margin="0,0,0,10">
                    <TextBlock Text="LogicalStation:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBox Width="60" Text="{Binding LogicalStationNumber}" Margin="0,0,20,0"/>

                    <TextBlock Text="ProductCode:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBox Width="160" Text="{Binding ProductCode}" Margin="0,0,20,0"/>

                    <TextBlock Text="Poll(ms):" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBox Width="60" Text="{Binding PollIntervalMs}" Margin="0,0,20,0"/>

                    <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Padding="10,6" Margin="0,0,10,0"/>
                    <Button Content="Connect + Start" Command="{Binding ConnectCommand}" Padding="10,6" Background="#4CAF50" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Connect (test only)" Command="{Binding ConnectTestOnlyCommand}" Padding="10,6" Background="#2196F3" Foreground="White" Margin="0,0,10,0"
                            ToolTip="Open PLC without polling trigger — use for read/write bench tests"/>
                    <Button Content="Stop + Disconnect" Command="{Binding DisconnectCommand}" Padding="10,6" Background="#F44336" Foreground="White"/>
                </WrapPanel>

                <TextBlock Text="{Binding StatusLine}" Foreground="#333" FontWeight="Bold" />
                <TextBlock Text="{Binding LastError}" Foreground="#B00020" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="PLC Address Mapping" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="TriggerBit" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TriggerBitDevice}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ClearErrorBit" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ClearErrorBitDevice}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="BusyBit" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BusyBitDevice}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="DoneBit" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DoneBitDevice}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="ResultCodeWord" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ResultCodeWordDevice}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="AppStateWord" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding AppStateWordDevice}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="DonePulse(ms)" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding DonePulseMs}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#DDD" BorderThickness="1" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Runtime Monitor" FontWeight="Bold" Margin="0,0,0,10"/>

                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="Connected:" FontWeight="Bold" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding IsConnected}"/>
                            <TextBlock Text="   Running:" FontWeight="Bold" Margin="20,0,6,0"/>
                            <TextBlock Text="{Binding IsRunning}"/>
                            <TextBlock Text="   State:" FontWeight="Bold" Margin="20,0,6,0"/>
                            <TextBlock Text="{Binding AppState}"/>
                        </WrapPanel>

                        <TextBlock Text="Log (chọn Ctrl+A rồi Ctrl+C để copy)" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding LogText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 MinHeight="120"
                                 MaxHeight="220"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Test / simulate -->
        <Border Grid.Row="2" Margin="10,0,10,10" Background="White" BorderBrush="#DDD" BorderThickness="1" Padding="12">
            <StackPanel>
                <TextBlock Text="Bàn thử giao tiếp (đọc/ghi địa chỉ tùy ý &amp; giả lập trạng thái)" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="11" Margin="0,0,0,10"
                           Text="Kết nối bằng «Connect (test only)» để chỉ mở MX Component không poll trigger, hoặc «Connect + Start» nếu cần chạy luồng tự động. Các nút dưới đây dùng địa chỉ đang nhập ở cột Mapping bên trái."/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Arbitrary R/W -->
                    <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" Padding="10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Đọc/ghi thử (device bất kỳ)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="Địa chỉ (VD: M100, D200, X0, Y0…)" FontSize="10" Foreground="#666"/>
                            <TextBox Text="{Binding TestDeviceAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>

                            <WrapPanel Margin="0,0,0,6">
                                <Button Content="Read bit" Command="{Binding TestReadBitCommand}" Padding="8,4" Margin="0,0,6,4"/>
                                <Button Content="Write 0" Command="{Binding TestWriteBit0Command}" Padding="8,4" Margin="0,0,6,4"/>
                                <Button Content="Write 1" Command="{Binding TestWriteBit1Command}" Padding="8,4" Margin="0,0,0,4"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,0,0,6">
                                <Button Content="Read word" Command="{Binding TestReadWordCommand}" Padding="8,4" Margin="0,0,6,4"/>
                                <TextBlock Text="Giá trị word:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox Width="56" Text="{Binding TestWordValueText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,6,4"/>
                                <Button Content="Write word" Command="{Binding TestWriteWordCommand}" Padding="8,4" Margin="0,0,0,4"/>
                            </WrapPanel>
                            <TextBlock Text="Kết quả đọc gần nhất:" FontSize="10" Foreground="#666"/>
                            <TextBlock Text="{Binding TestLastReadResult}" FontWeight="SemiBold" TextWrapping="Wrap"/>

                            <Button Content="Đọc snapshot mapping (Trigger/ClearErr/Busy/Done + 2 word)" Command="{Binding ReadMappedSnapshotCommand}" Padding="8,6" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Simulate PLC side -->
                    <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" Padding="10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Giả lập phía máy / PLC → PC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#666" Margin="0,0,0,8"
                                       Text="Ghi bit Trigger / ClearError như PLC để kiểm tra phản ứng của phần mềm."/>
                            <WrapPanel>
                                <Button Content="Trigger ON" Command="{Binding SimTriggerOnCommand}" Padding="8,4" Margin="0,0,6,4" Background="#FFF3E0"/>
                                <Button Content="Trigger OFF" Command="{Binding SimTriggerOffCommand}" Padding="8,4" Margin="0,0,0,4" Background="#FFF3E0"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,6,0,0">
                                <Button Content="ClearError ON" Command="{Binding SimClearErrorOnCommand}" Padding="8,4" Margin="0,0,6,4"/>
                                <Button Content="ClearError OFF" Command="{Binding SimClearErrorOffCommand}" Padding="8,4" Margin="0,0,0,4"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Simulate Vision / PC side -->
                    <Border Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Giả lập phía Vision (PC → PLC)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#666" Margin="0,0,0,8"
                                       Text="Ghi Busy/Done và word kết quả như app khi PLC đọc lại."/>
                            <WrapPanel>
                                <Button Content="Busy ON" Command="{Binding SimBusyOnCommand}" Padding="8,4" Margin="0,0,6,4" Background="#E8F5E9"/>
                                <Button Content="Busy OFF" Command="{Binding SimBusyOffCommand}" Padding="8,4" Margin="0,0,6,4" Background="#E8F5E9"/>
                                <Button Content="Pulse Done" Command="{Binding SimDonePulseCommand}" Padding="8,4" Margin="0,0,0,4" Background="#E8F5E9"/>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,4">
                                <TextBlock Text="ResultCode:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Width="48" Text="{Binding SimResultCodeText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Content="Write" Command="{Binding SimWriteResultCodeCommand}" Padding="8,4" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="AppState:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Width="48" Text="{Binding SimAppStateText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Content="Write" Command="{Binding SimWriteAppStateCommand}" Padding="8,4" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
