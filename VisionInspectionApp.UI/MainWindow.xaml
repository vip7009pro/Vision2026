<Window x:Class="VisionInspectionApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VisionInspectionApp.UI"
        xmlns:viewModels="clr-namespace:VisionInspectionApp.UI.ViewModels"
        xmlns:views="clr-namespace:VisionInspectionApp.UI.Views"
        mc:Ignorable="d"
        Title="Vision Inspection" Height="900" Width="1400">

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding Teach.UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding Teach.RedoCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:TeachViewModel}">
            <views:TeachView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ToolEditorViewModel}">
            <views:ToolEditorView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:InspectionViewModel}">
            <views:InspectionView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:CalibrationViewModel}">
            <views:CalibrationView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ManualInspectionViewModel}">
            <views:ManualInspectionView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <TabControl>
            <TabItem Header="Teach">
                <ContentControl Content="{Binding Teach}" />
            </TabItem>

            <TabItem Header="Tool Editor">
                <ContentControl Content="{Binding ToolEditor}" />
            </TabItem>

            <TabItem Header="Calibration">
                <ContentControl Content="{Binding Calibration}" />
            </TabItem>

            <TabItem Header="Manual Inspection">
                <ContentControl Content="{Binding ManualInspection}" />
            </TabItem>

            <TabItem Header="Inspection">
                <ContentControl Content="{Binding Inspection}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
